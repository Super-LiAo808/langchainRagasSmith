# 第三方 OpenAI 兼容 API（对话 + 向量可同服或分服配置）

# --- 硅基流动（默认，对话与 embedding 均支持）---
LLM_API_KEY=sk-your-siliconflow-api-key
LLM_API_BASE=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V3.1-Terminus
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# --- DeepSeek 仅对话（embedding 需另配硅基流动等）---
# LLM_API_KEY=sk-your-deepseek-api-key
# LLM_API_BASE=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# EMBEDDING_API_KEY=sk-your-siliconflow-api-key
# EMBEDDING_API_BASE=https://api.siliconflow.cn/v1
# EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# --- Moonshot 仅对话 ---
# LLM_API_KEY=sk-your-moonshot-api-key
# LLM_API_BASE=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-8k

# --- LangSmith（可选，用于 Tracing / 测试数据集）---
# LANGCHAIN_API_KEY=ls__your-langsmith-api-key
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=test-ragas
